meta {
  name: Google Login
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/google
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "idToken": "{{googleIdToken}}"
  }
}

script:post-response {
  const body = res.getBody();

  if (body && body.data && body.data.token) {
    bru.setEnvVar("authToken", body.data.token);
  }
}